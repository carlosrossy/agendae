// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────

enum TenantStatus {
  ACTIVE
  SUSPENDED
}

enum UserRole {
  OWNER
  STAFF
  CUSTOMER
}

enum UserStatus {
  ACTIVE
  INVITED
  DISABLED
}

enum ServiceStatus {
  ACTIVE
  ARCHIVED
}

enum ProfessionalStatus {
  ACTIVE
  ARCHIVED
}

enum BookingStatus {
  SCHEDULED
  CANCELLED
  COMPLETED
  NO_SHOW
}

// ─────────────────────────────────────────────────────────────
// MODELS
// ─────────────────────────────────────────────────────────────

model Tenant {
  id                      String        @id @db.Char(26)
  name                    String        @db.VarChar(100)
  slug                    String        @unique @db.VarChar(50)
  email                   String        @db.VarChar(255)
  phone                   String?       @db.VarChar(20)
  timezone                String        @db.VarChar(50)
  minimumLeadTimeMinutes  Int           @default(60) @map("minimum_lead_time_minutes")
  status                  TenantStatus  @default(ACTIVE)
  createdAt               DateTime      @default(now()) @map("created_at")
  updatedAt               DateTime      @updatedAt @map("updated_at")

  // Relations
  users          User[]
  services       Service[]
  professionals  Professional[]
  customers      Customer[]
  bookings       Booking[]

  @@map("tenants")
}

model User {
  id            String     @id @db.Char(26)
  tenantId      String     @map("tenant_id") @db.Char(26)
  name          String     @db.VarChar(100)
  email         String     @db.VarChar(255)
  passwordHash  String?    @map("password_hash") @db.VarChar(255)
  role          UserRole
  status        UserStatus @default(ACTIVE)
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  professional   Professional?
  customer       Customer?

  @@unique([tenantId, email], name: "tenant_email_unique")
  @@index([tenantId])
  @@map("users")
}

model Service {
  id               String        @id @db.Char(26)
  tenantId         String        @map("tenant_id") @db.Char(26)
  name             String        @db.VarChar(100)
  description      String?       @db.VarChar(500)
  durationMinutes  Int           @map("duration_minutes")
  priceCents       Int           @map("price_cents")
  requiresPayment  Boolean       @default(false) @map("requires_payment")
  status           ServiceStatus @default(ACTIVE)
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  tenant            Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  professionals     ProfessionalService[]
  bookings          Booking[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("services")
}

model Professional {
  id              String              @id @db.Char(26)
  tenantId        String              @map("tenant_id") @db.Char(26)
  userId          String?             @unique @map("user_id") @db.Char(26)
  name            String              @db.VarChar(100)
  bio             String?             @db.VarChar(500)
  businessHours   Json                @map("business_hours")
  status          ProfessionalStatus  @default(ACTIVE)
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  tenant        Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user          User?                   @relation(fields: [userId], references: [id], onDelete: SetNull)
  services      ProfessionalService[]
  bookings      Booking[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("professionals")
}

model Customer {
  id         String   @id @db.Char(26)
  tenantId   String   @map("tenant_id") @db.Char(26)
  userId     String?  @unique @map("user_id") @db.Char(26)
  name       String   @db.VarChar(100)
  email      String   @db.VarChar(255)
  phone      String?  @db.VarChar(20)
  notes      String?  @db.VarChar(1000)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  bookings  Booking[]

  @@unique([tenantId, email], name: "customer_tenant_email_unique")
  @@index([tenantId])
  @@map("customers")
}

model ProfessionalService {
  professionalId String @map("professional_id") @db.Char(26)
  serviceId      String @map("service_id") @db.Char(26)
  tenantId       String @map("tenant_id") @db.Char(26)

  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  service        Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([professionalId, serviceId])
  @@index([tenantId])
  @@index([serviceId])
  @@map("professional_services")
}

model Booking {
  id                  String         @id @db.Char(26)
  tenantId            String         @map("tenant_id") @db.Char(26)
  customerId          String         @map("customer_id") @db.Char(26)
  professionalId      String         @map("professional_id") @db.Char(26)
  serviceId           String         @map("service_id") @db.Char(26)
  startAt             DateTime       @map("start_at")
  endAt               DateTime       @map("end_at")
  priceCents          Int            @map("price_cents")
  status              BookingStatus  @default(SCHEDULED)
  cancellationReason  String?        @map("cancellation_reason") @db.VarChar(500)
  notes               String?        @db.VarChar(1000)
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer     Customer     @relation(fields: [customerId], references: [id], onDelete: Restrict)
  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Restrict)
  service      Service      @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([tenantId, professionalId, startAt])
  @@index([tenantId, customerId])
  @@index([startAt])
  @@map("bookings")
}