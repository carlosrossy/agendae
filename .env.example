# ============================================
# Application
# ============================================
NODE_ENV=development
APP_URL=http://localhost:3000
APP_NAME=agendaê

TENANT_RESOLUTION_MODE=slug

# ============================================
# Database (PostgreSQL)
# ============================================

DATABASE_URL=postgresql://agendae:agendae@localhost:5432/agendae?schema=public

DIRECT_URL=postgresql://agendae:agendae@localhost:5432/agendae?schema=public

# ============================================
# Auth (NextAuth / Auth.js v5)
# ============================================
AUTH_SECRET=change-me-use-openssl-rand-base64-32
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ============================================
# Observability
# ============================================
LOG_LEVEL=debug